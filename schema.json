    "homelab:index:OpnsenseUnboundForward": {
      "description": "Manages an Unbound DNS query forward on an OPNsense appliance via the REST API.",
      "inputProperties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether the forward is enabled. Default: true."
        },
        "type": {
          "type": "string",
          "description": "Forward type: forward or dot (DNS over TLS). Default: forward."
        },
        "domain": {
          "type": "string",
          "description": "Domain to forward queries for (empty for all)."
        },
        "server": {
          "type": "string",
          "description": "DNS server IP address."
        },
        "port": {
          "type": "integer",
          "description": "DNS server port."
        },
        "verify": {
          "type": "string",
          "description": "TLS verification hostname (for DoT)."
        },
        "forwardTcpUpstream": {
          "type": "boolean",
          "description": "Whether to use TCP for upstream queries. Default: false."
        },
        "forwardFirst": {
          "type": "boolean",
          "description": "Whether to try forwarding first before resolving. Default: false."
        },
        "description": {
          "type": "string",
          "description": "Description of the forward entry."
        }
