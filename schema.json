          "type": "boolean",
          "description": "Whether the host override is enabled. Default: true."
        },
        "hostname": {
          "type": "string",
          "description": "Hostname (e.g., myhost)."
        },
        "domain": {
          "type": "string",
          "description": "Domain name (e.g., example.com)."
        },
        "rr": {
          "type": "string",
          "description": "DNS record type (A, AAAA, MX, TXT). Default: A."
        },
        "server": {
          "type": "string",
          "description": "IP address or target for the override."
        },
        "mxprio": {
          "type": "integer",
          "description": "MX priority (for MX records)."
        },
        "mx": {
          "type": "string",
          "description": "MX mail server hostname."
