{
  "name": "homelab",
  "displayName": "Homelab",
  "version": "0.3.1",
  "pluginDownloadURL": "github://api.github.com/tyevco/pulumi-homelab",
  "description": "A Pulumi provider for managing homelab infrastructure including Docker Compose stacks, LXC containers, Traefik routes, and OPNsense firewall rules",
  "keywords": [
    "pulumi",
    "homelab",
    "docker-compose",
    "lxc",
    "opnsense",
    "firewall",
    "category/infrastructure"
  ],
  "license": "Apache-2.0",
  "config": {
    "variables": {
      "url": {
        "type": "string",
        "description": "The URL of the homelab server (e.g., http://192.168.1.100:5001)"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for authenticating with the homelab REST API",
        "secret": true
      },
      "opnsenseUrl": {
        "type": "string",
        "description": "The URL of the OPNsense server (e.g., https://192.168.1.1)"
      },
      "opnsenseApiKey": {
        "type": "string",
        "description": "API key for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseApiSecret": {
        "type": "string",
        "description": "API secret for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseInsecure": {
        "type": "boolean",
        "description": "Skip TLS certificate verification for OPNsense API (default: false)",
        "default": false
      }
    }
  },
  "provider": {
    "description": "The Homelab provider configuration.",
    "inputProperties": {
      "url": {
        "type": "string",
        "description": "The URL of the homelab server (e.g., http://192.168.1.100:5001)"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for authenticating with the homelab REST API",
        "secret": true
      },
      "opnsenseUrl": {
        "type": "string",
        "description": "The URL of the OPNsense server (e.g., https://192.168.1.1)"
      },
      "opnsenseApiKey": {
        "type": "string",
        "description": "API key for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseApiSecret": {
        "type": "string",
        "description": "API secret for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseInsecure": {
        "type": "boolean",
        "description": "Skip TLS certificate verification for OPNsense API (default: false)"
      }
    },
    "properties": {
      "url": {
        "type": "string",
        "description": "The URL of the homelab server"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for authenticating with the homelab REST API",
        "secret": true
      },
      "opnsenseUrl": {
        "type": "string",
        "description": "The URL of the OPNsense server"
      },
      "opnsenseApiKey": {
        "type": "string",
        "description": "API key for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseApiSecret": {
        "type": "string",
        "description": "API secret for authenticating with the OPNsense REST API",
        "secret": true
      },
      "opnsenseInsecure": {
        "type": "boolean",
        "description": "Skip TLS certificate verification for OPNsense API"
      }
    }
  },
  "types": {
    "homelab:index:ContainerInfo": {
      "type": "object",
      "description": "Information about a container within a stack.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Container name"
        },
        "service": {
          "type": "string",
          "description": "Docker Compose service name"
        },
        "image": {
          "type": "string",
          "description": "Container image"
        },
        "state": {
          "type": "string",
          "description": "Container state (running, exited, etc.)"
        },
        "status": {
          "type": "string",
          "description": "Human-readable container status"
        },
        "health": {
          "type": "string",
          "description": "Container health status"
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Port mappings"
        }
      }
    }
  },
  "resources": {
    "homelab:index:Stack": {
      "description": "Manages a Docker Compose stack on a homelab server via the REST API. Supports creating, updating, starting, stopping, and deleting stacks.",
      "inputProperties": {
        "name": {
          "type": "string",
          "description": "The stack name. Must be unique on the homelab server."
        },
        "composeYaml": {
          "type": "string",
          "description": "The Docker Compose YAML content for this stack."
        },
        "envFile": {
          "type": "string",
          "description": "Optional .env file content for the stack."
        },
        "composeOverride": {
          "type": "string",
          "description": "Optional docker-compose.override.yml content for the stack."
        },
        "autostart": {
          "type": "boolean",
          "description": "Whether the stack should autostart (default: false).",
          "default": false
        },
        "displayName": {
          "type": "string",
          "description": "Optional display name for the stack."
        },
        "running": {
          "type": "boolean",
          "description": "Whether the stack should be running (default: true).",
          "default": true
        }
      },
      "requiredInputs": [
        "name",
        "composeYaml"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The stack name."
        },
        "composeYaml": {
          "type": "string",
          "description": "The Docker Compose YAML content."
        },
        "envFile": {
          "type": "string",
          "description": "The .env file content."
        },
        "composeOverride": {
          "type": "string",
          "description": "The docker-compose.override.yml content."
        },
        "autostart": {
          "type": "boolean",
          "description": "Whether the stack autostarts."
        },
        "displayName": {
          "type": "string",
          "description": "The display name for the stack."
        },
        "running": {
          "type": "boolean",
          "description": "Whether the stack is running."
        },
        "status": {
          "type": "string",
          "description": "The current stack status (running, exited, stopped, partial, unknown)."
        },
        "containers": {
          "type": "array",
          "items": {
            "$ref": "#/types/homelab:index:ContainerInfo"
          },
          "description": "Information about the containers in this stack."
        }
      },
      "required": [
        "name",
        "composeYaml"
      ]
    },
    "homelab:index:TraefikStaticConfig": {
      "description": "Manages the Traefik static configuration file (traefik.yml) via the homelab REST API.",
      "inputProperties": {
        "content": {
          "type": "string",
          "description": "The YAML content of the Traefik static configuration file."
        }
      },
      "requiredInputs": [
        "content"
      ],
      "properties": {
        "content": {
          "type": "string",
          "description": "The YAML content of the static configuration."
        },
        "lastModified": {
          "type": "string",
          "description": "ISO 8601 timestamp of the last modification."
        }
      },
      "required": [
        "content"
      ]
    },
    "homelab:index:TraefikRoute": {
      "description": "Manages a Traefik dynamic route configuration file via the homelab REST API.",
      "inputProperties": {
        "name": {
          "type": "string",
          "description": "The route name (maps to filename: name → configs/name.yml). Must match ^[a-z0-9_-]+$."
        },
        "content": {
          "type": "string",
          "description": "The YAML content of the route configuration file."
        }
      },
      "requiredInputs": [
        "name",
        "content"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The route name."
        },
        "content": {
          "type": "string",
          "description": "The YAML content of the route configuration."
        },
        "lastModified": {
          "type": "string",
          "description": "ISO 8601 timestamp of the last modification."
        }
      },
      "required": [
        "name",
        "content"
      ]
    },
    "homelab:index:OpnsenseFirewallRule": {
      "description": "Manages a firewall filter rule on an OPNsense appliance via the REST API.",
      "inputProperties": {
        "description": {
          "type": "string",
          "description": "Description of the firewall rule."
        },
        "interface": {
          "type": "string",
          "description": "Network interface (e.g., lan, wan, opt1)."
        },
        "ipprotocol": {
          "type": "string",
          "description": "IP protocol version: inet (IPv4), inet6 (IPv6), or inet46 (both). Default: inet."
        },
        "protocol": {
          "type": "string",
          "description": "Protocol to match (e.g., any, TCP, UDP, TCP/UDP, ICMP). Default: any."
        },
        "sourceNet": {
          "type": "string",
          "description": "Source network or address (e.g., any, 192.168.1.0/24, or an alias name)."
        },
        "sourcePort": {
          "type": "string",
          "description": "Source port or port range."
        },
        "destinationNet": {
          "type": "string",
          "description": "Destination network or address."
        },
        "destinationPort": {
          "type": "string",
          "description": "Destination port or port range."
        },
        "action": {
          "type": "string",
          "description": "Rule action: pass, block, or reject."
        },
        "direction": {
          "type": "string",
          "description": "Traffic direction: in or out. Default: in."
        },
        "log": {
          "type": "boolean",
          "description": "Whether to log packets matching this rule."
        },
        "quick": {
          "type": "boolean",
          "description": "Apply quick match (stop processing after this rule). Default: true."
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the rule is disabled."
        },
        "sequence": {
          "type": "integer",
          "description": "Rule priority/order sequence number."
        }
      },
      "requiredInputs": [
        "action",
        "interface"
      ],
      "properties": {
        "uuid": {
          "type": "string",
          "description": "The UUID assigned by OPNsense."
        },
        "description": {
          "type": "string",
          "description": "Description of the firewall rule."
        },
        "interface": {
          "type": "string",
          "description": "Network interface."
        },
        "ipprotocol": {
          "type": "string",
          "description": "IP protocol version."
        },
        "protocol": {
          "type": "string",
          "description": "Protocol to match."
        },
        "sourceNet": {
          "type": "string",
          "description": "Source network or address."
        },
        "sourcePort": {
          "type": "string",
          "description": "Source port or port range."
        },
        "destinationNet": {
          "type": "string",
          "description": "Destination network or address."
        },
        "destinationPort": {
          "type": "string",
          "description": "Destination port or port range."
        },
        "action": {
          "type": "string",
          "description": "Rule action."
        },
        "direction": {
          "type": "string",
          "description": "Traffic direction."
        },
        "log": {
          "type": "boolean",
          "description": "Whether to log matching packets."
        },
        "quick": {
          "type": "boolean",
          "description": "Apply quick match."
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the rule is disabled."
        },
        "sequence": {
          "type": "integer",
          "description": "Rule priority/order sequence number."
        }
      },
      "required": [
        "uuid",
        "action",
        "interface"
      ]
    },
    "homelab:index:OpnsenseAlias": {
      "description": "Manages a firewall alias on an OPNsense appliance via the REST API.",
      "inputProperties": {
        "name": {
          "type": "string",
          "description": "The alias name. Must be unique."
        },
        "type": {
          "type": "string",
          "description": "Alias type: host, network, port, mac, url, or urltable."
